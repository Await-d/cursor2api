NODE_ENV=production
PORT=3010
TIMEOUT=120

# ⚠️ 部署到海外机器通常不需要代理；国内云可按需启用
# PROXY=http://host.docker.internal:7890

# 默认回退模型（未命中映射时使用）
CURSOR_MODEL=anthropic/claude-sonnet-4.6
SYSTEM_PROMPT_INJECT=

# 请求模型映射表（JSON 字符串）
# key = 客户端请求模型名，value = 实际转发给 Cursor 的模型名
# 支持 "*" 作为兜底映射
MODEL_MAPPING={"claude-sonnet-4-6":"anthropic/claude-sonnet-4.6","claude-sonnet-4.6":"anthropic/claude-sonnet-4.6","claude-opus-4-6":"anthropic/claude-opus-4.6","claude-opus-4.6":"anthropic/claude-opus-4.6","gemini-3-flash":"google/gemini-3-flash","gemini-3.1-pro":"google/gemini-3.1-pro","gemini-3-pro":"google/gemini-3-pro","gpt-5.3-codex":"openai/gpt-5.3-codex","gpt-5.4":"openai/gpt-5.4","gpt-5.4-pro":"openai/gpt-5.4-pro","*":"anthropic/claude-sonnet-4.6"}

# 可选：Cursor 验证脚本 URL（会覆盖 config.yaml）
# SCRIPT_URL=https://cursor.com/.../c.js?... 

# 可选：浏览器指纹 base64（会覆盖 config.yaml）
# FP=ey...
