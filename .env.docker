TIMEOUT=120

# ⚠️ 部署到海外机器通常不需要代理；国内云可按需启用
PROXY=

# 代理池轮询（逗号分隔或 JSON 数组）。配置后每次请求轮询选取，429 时自动切换
PROXY_POOL=["socks5://192.168.123.3:1084","socks5://192.168.123.3:1085","socks5://192.168.123.3:1086","socks5://192.168.123.3:1087","socks5://192.168.123.3:1088","http://192.168.123.3:1086","http://192.168.123.3:1088","http://192.168.123.3:1089"]

CONCURRENCY=8

# 默认回退模型（未命中映射时使用）
CURSOR_MODEL=anthropic/claude-sonnet-4.6
SYSTEM_PROMPT_INJECT=
ENABLE_THINKING=false

# 请求模型映射表（JSON 字符串）
# key = 客户端请求模型名，value = 实际转发给 Cursor 的模型名
# 支持 "*" 作为兜底映射
MODEL_MAPPING={"claude-sonnet-4-6":"anthropic/claude-sonnet-4.6","claude-sonnet-4.6":"anthropic/claude-sonnet-4.6","claude-opus-4-6":"anthropic/claude-opus-4.6","claude-opus-4.6":"anthropic/claude-opus-4.6","gemini-3-flash":"google/gemini-3-flash","gemini-3.1-pro":"google/gemini-3.1-pro","gemini-3-pro":"google/gemini-3-pro","gemini-3.1-pro-preview":"google/gemini-3.1-pro-preview","gemini-3.1-flash":"google/gemini-3.1-flash","gemini-3.1-flash-preview":"google/gemini-3.1-flash-preview","gemini-3-pro-preview":"google/gemini-3-pro-preview","gemini-3-flash-preview":"google/gemini-3-flash-preview","gpt-5.3-codex":"openai/gpt-5.3-codex","gpt-5.4":"openai/gpt-5.4","gpt-5.4-pro":"openai/gpt-5.4-pro","*":"anthropic/claude-sonnet-4.6"}

# 可选：Cursor 验证脚本 URL（会覆盖 config.yaml）
# SCRIPT_URL=https://cursor.com/.../c.js?... 

# 可选：浏览器指纹 base64（会覆盖 config.yaml）
# FP=ey...
