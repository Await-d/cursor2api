{
  "name": "cursor2api",
  "version": "2.6.6-fork.1",
  "description": "Proxy Cursor docs AI to Anthropic Messages API for Claude Code",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "docker:build": "docker compose build",
    "docker:up": "docker compose up -d",
    "docker:deploy": "docker compose up -d --build --force-recreate --remove-orphans",
    "docker:logs": "docker compose logs -f --tail=200",
    "test:unit": "node test/unit-tolerant-parse.mjs",

    "test:retry-prompt-pool": "node --import tsx test/unit-retry-prompt-pool.mjs",
    "test:sanitize-response": "node --import tsx test/unit-sanitize-response.mjs",
    "test:proxy-subscriptions": "node --import tsx test/unit-proxy-subscriptions.mjs",
    "test:airport-runtime": "node --import tsx test/unit-airport-runtime.mjs",
    "test:tool-fixer": "node test/unit-tool-fixer.mjs",
    "test:openai-compat": "node test/unit-openai-compat.mjs",
    "test:thinking": "node --import tsx test/unit-thinking.mjs",
    "test:converter-features": "node --import tsx test/unit-converter-features.mjs",
    "test:truncation": "node --import tsx test/unit-truncation-recovery.mjs",
    "test:all": "node test/unit-tolerant-parse.mjs && node --import tsx test/unit-retry-prompt-pool.mjs && node --import tsx test/unit-sanitize-response.mjs && node --import tsx test/unit-proxy-subscriptions.mjs && node --import tsx test/unit-airport-runtime.mjs && node test/unit-tool-fixer.mjs && node test/unit-openai-compat.mjs && node --import tsx test/unit-thinking.mjs && node --import tsx test/unit-converter-features.mjs && node --import tsx test/unit-truncation-recovery.mjs",

    "test:e2e": "node test/e2e-chat.mjs",
    "test:agentic": "node test/e2e-agentic.mjs"
  },
  "dependencies": {
    "dotenv": "^16.5.0",
    "eventsource-parser": "^3.0.1",
    "express": "^5.1.0",
    "https-proxy-agent": "^7.0.6",
    "socks-proxy-agent": "^8.0.5",
    "tesseract.js": "^7.0.0",
    "undici": "^7.22.0",
    "uuid": "^11.1.0",
    "yaml": "^2.7.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.2",
    "@types/node": "^22.15.0",
    "@types/uuid": "^10.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0"
  }
}
